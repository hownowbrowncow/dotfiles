# ── Readline Configuration ────────────────────────────────────────────────────
# Applied to all programs that use GNU Readline (bash, python REPL, etc.)

# Case-insensitive tab completion
set completion-ignore-case on

# Treat hyphens and underscores as equivalent during completion
set completion-map-case on

# Show all completions on first tab press (instead of beeping)
set show-all-if-ambiguous on

# Show all completions if there are multiple matches with no partial completion
set show-all-if-unmodified on

# Skip completed text when pasting (avoids duplication)
set skip-completed-text on

# Color files by type during completion (like ls)
set colored-stats on

# Color the common prefix of completions
set colored-completion-prefix on

# Append a character to indicate file type (/ for dirs, @ for symlinks, etc.)
set visible-stats on

# Use visible bell instead of audible
set bell-style visible

# Enable 8-bit input/output (UTF-8 support)
set input-meta on
set output-meta on
set convert-meta off

# ── Key Bindings ──────────────────────────────────────────────────────────────
# Cycle through completions with Tab / Shift-Tab
TAB: menu-complete
"\e[Z": menu-complete-backward

# Up/Down arrows search history with current prefix
"\e[A": history-search-backward
"\e[B": history-search-forward

# Ctrl-Left/Right to move by word
"\e[1;5D": backward-word
"\e[1;5C": forward-word
